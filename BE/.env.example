# Backend runtime
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="8h"

# Public contact fallback
# Admin settings in DB are preferred; this is only a fallback.
ZALO_PHONE=""

# Cloudinary image upload
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Future email notification config
# SendGrid is the primary provider for the planned email phase.
SENDGRID_API_KEY=""
EMAIL_FROM="HenryTravel <noreply@example.com>"
ADMIN_EMAIL=""
PUBLIC_APP_URL="http://localhost:3000"

# Optional SMTP fallback for future email phase
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
